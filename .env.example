# --- App Configuration ---
APP_NAME=Anchor Cloud
APP_ENV=development
APP_PORT=8000
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=anchor_user
# Use a placeholder, never a real password
MYSQL_PASSWORD=your_database_password_here
MYSQL_DATABASE=anchor_cloud

# --- Security & Auth ---
# Add these keys so you remember to set them in Render!
SECRET_KEY=generate_a_random_hex_string_here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Storage ---
UPLOAD_DIR=./vault_storage
FRONTEND_ORIGIN=http://localhost:8000