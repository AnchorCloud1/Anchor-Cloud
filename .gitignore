# ============================================================
# .gitignore — Anchor Cloud
# ============================================================

# Environment — NEVER commit this
.env
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
dist/
build/

# Vault storage — encrypted blobs (too large + sensitive for git)
vault_storage/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/